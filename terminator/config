[global_config]
  dbus = False
  handle_size = 0
  homogeneous_tabbar = False
  scroll_tabbar = True
  suppress_multiple_term_dialog = True
  title_hide_sizetext = True
  title_transmit_bg_color = "#555753"
  window_state = maximise
[keybindings]
  paste = <Primary><Shift>Cyrillic_em
[layouts]
  [[default]]
    [[[child0]]]
      order = 0
      parent = ""
      type = Window
    [[[child1]]]
      order = 0
      parent = child0
      ratio = 0.6
      type = HPaned
    [[[terminal0]]]
      command = cd projects && nvim
      directory = ""
      order = 0
      parent = child1
      profile = default
      type = Terminal
    [[[terminal1]]]
      command = cd projects && zsh
      directory = ""
      order = 1
      parent = child1
      profile = default
      type = Terminal
[plugins]
[profiles]
  [[default]]
    cursor_color = "#aaaaaa"
    cursor_shape = ibeam
    scrollbar_position = hidden
    show_titlebar = False
